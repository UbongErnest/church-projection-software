{
  "entities": {
    "User": {
      "title": "User",
      "description": "Information about a registered church production member or pastor",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The Firebase Authentication unique user ID" },
        "email": { "type": "string", "description": "User email address" },
        "displayName": { "type": "string", "description": "Display name of the user/pastor" },
        "createdAt": { "type": "string", "format": "date-time", "description": "The raw date-time string when registry occurred" },
        "churchName": { "type": "string", "description": "The name of the church" },
        "country": { "type": "string", "description": "The country of the church" },
        "state": { "type": "string", "description": "The state where the church is situated" },
        "city": { "type": "string", "description": "The city where the church is situated" },
        "location": { "type": "string", "description": "Specific street location or address of the temple" },
        "denomination": { "type": "string", "description": "The church denomination affiliation" },
        "subscriptionPlan": { "type": "string", "description": "Ecclesiastical billing tier: 'free', 'monthly', 'yearly'" },
        "subscriptionStatus": { "type": "string", "description": "Status of payment: 'active', 'past_due', etc." },
        "subscriptionExpiresAt": { "type": "string", "description": "Expiry ISO string" }
      },
      "required": ["uid", "email", "churchName", "country", "state", "city", "location", "denomination", "subscriptionPlan", "subscriptionStatus"]
    },
    "SermonNote": {
      "title": "SermonNote",
      "description": "Sermon and preaching notes taken by registered church users",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier of the note" },
        "userId": { "type": "string", "description": "The user ID of the author" },
        "title": { "type": "string", "description": "The subject/topic of the sermon" },
        "content": { "type": "string", "description": "Rich content notes of the sermon" },
        "createdAt": { "type": "string", "description": "Formatted date label" },
        "timestamp": { "type": "string", "description": "Formatted time string" },
        "rawDate": { "type": "number", "description": "Epoch timestamp used for sorting" }
      },
      "required": ["id", "userId", "title", "content", "rawDate"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Registered user accounts profile"
    },
    "/sermonNotes/{noteId}": {
      "schema": "SermonNote",
      "description": "Sermon notes saved by user accounts"
    }
  }
}
