{
  "version": 2,
  "buildCommand": "npm run build",
  "functions": {
    "api/payment/initialize.ts": {
      "runtime": "nodejs24.x"
    },
    "api/payment/verify.ts": {
      "runtime": "nodejs24.x"
    }
  },
  "builds": [
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["src/BibleData/**"]
      }
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}