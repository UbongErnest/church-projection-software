rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Catch-All Global Safety Net (Strictly Deny-By-Default)
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable Security Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Users Profiles Collection
    match /users/{userId} {
      allow get: if isSignedIn() && isOwner(userId);
      
      allow create: if isSignedIn() 
        && userId == request.auth.uid
        && incoming().uid == request.auth.uid
        && incoming().email == request.auth.token.email
        && incoming().keys().hasAll(['uid', 'email', 'displayName', 'createdAt', 'churchName', 'country', 'state', 'city', 'location', 'denomination', 'subscriptionPlan', 'subscriptionStatus'])
        && incoming().keys().size() >= 12 && incoming().keys().size() <= 13;
        
      allow update: if isSignedIn() 
        && isOwner(userId)
        && incoming().uid == existing().uid
        && incoming().email == existing().email
        && incoming().keys().hasAll(['uid', 'email', 'displayName', 'createdAt', 'churchName', 'country', 'state', 'city', 'location', 'denomination', 'subscriptionPlan', 'subscriptionStatus'])
        && incoming().keys().size() >= 12 && incoming().keys().size() <= 13;
        
      allow delete: if false; // Profiles cannot be web-deleted for regulatory trace
    }

    // 3. Sermon Notes Collection (Authenticated User Workspace)
    match /sermonNotes/{noteId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      
      // Query Enforcer Check (Forces secure formulation on client fetches)
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn()
        && isValidId(noteId)
        && incoming().userId == request.auth.uid
        && incoming().id == noteId
        && incoming().keys().hasAll(['id', 'userId', 'title', 'content', 'createdAt', 'timestamp', 'rawDate'])
        && incoming().keys().size() == 7
        && incoming().title is string && incoming().title.size() <= 300
        && incoming().content is string && incoming().content.size() <= 100000;

      allow update: if isSignedIn()
        && isValidId(noteId)
        && isOwner(existing().userId)
        && incoming().userId == existing().userId
        && incoming().id == existing().id
        && incoming().keys().hasAll(['id', 'userId', 'title', 'content', 'createdAt', 'timestamp', 'rawDate'])
        && incoming().keys().size() == 7
        && incoming().title is string && incoming().title.size() <= 300
        && incoming().content is string && incoming().content.size() <= 100000;

      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
  }
}
