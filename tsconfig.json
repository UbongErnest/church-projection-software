{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@/server/*": ["./src/server/*"],
      "@/server/payments": ["./src/server/payments.ts"],
      "@/server/userProfiles": ["./src/server/userProfiles.ts"],
      "@/bibleDatabase": ["./src/bibleDatabase.ts"],
      "@/BibleData/*": ["./src/BibleData/*"]
    },
    "rootDir": ".",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "noEmit": true
  }
}
